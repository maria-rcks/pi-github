  "description": "GitHub tool extension for Pi: format threads, list issues/PRs, and inspect PR diffs/images.",
  "author": "Maria <maria@kuuro.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maria-rcks/pi-github.git"
  },
  "bugs": {
    "url": "https://github.com/maria-rcks/pi-github/issues"
  },
  "homepage": "https://github.com/maria-rcks/pi-github#readme",
  "keywords": [
    "pi-package",
    "pi",
    "pi-agent",
    "github",
    "extension"
  ],
